{
  "name": "karajan-rag",
  "version": "0.1.0",
  "description": "Orquestador multi-CLI para proveedores de IA (Codex, Claude, Gemini) basado en spawn",
  "type": "module",
  "main": "index.js",
  "bin": {
    "karajan-rag": "bin/karajan-rag.js"
  },
  "scripts": {
    "start": "node index.js",
    "lint": "eslint .",
    "test": "node --test tests/*.test.js",
    "coverage": "c8 node --test tests/*.test.js",
    "smoke": "RUN_SMOKE=1 node scripts/smoke.js",
    "smoke:codex": "RUN_SMOKE=1 node scripts/smoke.js codex",
    "smoke:claude": "RUN_SMOKE=1 node scripts/smoke.js claude",
    "smoke:gemini": "RUN_SMOKE=1 node scripts/smoke.js gemini",
    "smoke:ollama": "RUN_SMOKE=1 node scripts/smoke.js ollama"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "rag",
    "cli",
    "ai",
    "orchestrator",
    "codex",
    "claude",
    "gemini"
  ],
  "author": "",
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "pg": "^8.20.0"
  }
}
